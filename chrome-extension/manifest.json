{
  "manifest_version": 3,
  "name": "AI Browser",
  "version": "2.0.0",
  "description": "AI 驱动的浏览器助手 - 智能对话、划词工具、脚本管理",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "sidePanel",
    "contextMenus"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "action": {
    "default_title": "AI Browser",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "js": ["content/index.js"],
      "css": ["content/content.css"],
      "matches": ["<all_urls>"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidepanel/sidepanel.html", "content/*", "shared/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+A" }
    },
    "open-sidebar": {
      "description": "打开侧边栏"
    }
  }
}
